NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_OR_PUBLISHABLE_DEFAULT_KEY
# Service role key — from Supabase dashboard → Settings → API → service_role
# Used only in server-side API routes (never exposed to the browser)
SUPABASE_SERVICE_ROLE_KEY=

# For local development use true
NEXT_PUBLIC_OFFLINE_MODE=true 
